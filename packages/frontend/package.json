{
  "name": "@hopi/frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --hot ./dev.ts",
    "remote": "HOPI_FRONTEND_HMR=0 bun ./dev.ts",
    "build": "bun run ./build.ts",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.dev.json --noEmit",
    "test": "bun test",
    "check": "bun run typecheck && bun test && bun run build"
  },
  "dependencies": {
    "@heroui/react": "3.2.2",
    "@heroui/styles": "3.2.2",
    "@tanstack/react-query": "^5.90.10",
    "lucide-react": "^0.554.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.9.5",
    "react-virtuoso": "^4.14.1",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-plugin-tailwind": "0.1.2",
    "typescript": "~6.0.2"
  }
}
