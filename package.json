{
  "name": "hopi-agent-orchestrator-root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "cd packages/backend && bun dev",
    "dev:frontend": "cd packages/frontend && bun run dev",
    "dev": "bun run dev:backend && bun run dev:frontend",
    "check:frontend": "cd packages/frontend && bun run check",
    "check": "bun run check:backend",
    "check:backend": "cd packages/backend && bun run check"
  }
}
